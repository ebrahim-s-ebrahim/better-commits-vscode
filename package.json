{
  "name": "better-commits-vscode",
  "displayName": "Better Commits",
  "description": "A guided conventional commit message wizard integrated into VS Code's Source Control panel",
  "version": "0.1.0",
  "publisher": "ebrahim-s-ebrahim",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers",
    "Other"
  ],
  "keywords": [
    "git",
    "commit",
    "conventional-commits",
    "source-control"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "betterCommits.commit",
        "title": "Better Commits: Compose Commit Message",
        "icon": "$(edit)"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "betterCommits.commit",
          "group": "navigation",
          "when": "scmProvider == git"
        }
      ]
    },
    "configuration": {
      "title": "Better Commits",
      "properties": {
        "betterCommits.configFile": {
          "type": "string",
          "default": ".better-commits.json",
          "description": "Name of the config file to look for in the workspace root"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "test:unit": "npm run compile && mocha dist/test/unit/**/*.test.js --ui tdd --color --timeout 10000",
    "test:integration": "npm run compile && node dist/test/runIntegrationTests.js",
    "test": "npm run test:unit"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.5.2",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "typescript": "^5.4.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ebrahim-s-ebrahim/better-commits-vscode.git"
  }
}
